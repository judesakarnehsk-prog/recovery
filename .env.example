# Supabase — https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Stripe — https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...        # From: Stripe Dashboard → Webhooks → endpoint secret
STRIPE_CONNECT_CLIENT_ID=ca_...        # From: Stripe Dashboard → Connect → Settings → Client ID

# Stripe Customer Portal config ID (optional but recommended)
# From: Stripe Dashboard → Settings → Billing → Customer portal → Configuration ID
STRIPE_PORTAL_CONFIG_ID=bpc_...

# Stripe Price IDs — create in Stripe Dashboard → Products
STRIPE_STARTER_PRICE_ID=price_...      # $29/mo Starter plan
STRIPE_GROWTH_PRICE_ID=price_...       # $79/mo Growth plan
STRIPE_SCALE_PRICE_ID=price_...        # $149/mo Scale plan

# Public price IDs (needed client-side for upgrade buttons)
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_GROWTH_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_SCALE_PRICE_ID=price_...

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=billing@revorva.com

# Anthropic Claude AI — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to https://revorva.com in production

# Google Analytics 4 — https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-...

# Admin (comma-separated emails that can access /admin)
ADMIN_EMAILS=your@email.com

# Cron security — run: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
